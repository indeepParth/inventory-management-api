{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../Data/inventory.db"
  },
  "Jwt": {
    "Issuer": "InventoryManagement",
    "Audience": "InventoryManagementUsers",
    "AccessTokenLifetimeMinutes": 60
  },
  "Authentication": {
    "AllowPublicRegistration": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Login": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Register": {
      "PermitLimit": 20,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "RefreshToken": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  }
}
