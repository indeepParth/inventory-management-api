# Copy this file to .env for one production client deployment.
# Keep each client's .env outside source control.

# Frontend static container
FRONTEND_HTTP_PORT=8080
VITE_API_BASE_URL=https://api.client.example.com

# API JWT settings
Jwt__Issuer=InventoryManagement
Jwt__Audience=InventoryManagement
Jwt__Key=replace-with-a-long-random-production-secret

# Keep false after the database is initialized.
# For a first Docker deployment with a new named volume, set true once,
# start the stack successfully, then set false again and restart.
Database__ApplyMigrationsOnStartup=false

# Browser origin allowed to call the API
Cors__AllowedOrigins__0=https://inventory.client.example.com

# Trusted reverse proxy network or proxy IP
ReverseProxy__KnownNetworks__0=172.18.0.0/16

# Optional one-time admin bootstrap.
# Keep disabled after the first admin user exists.
Bootstrap__Admin__Enabled=false
Bootstrap__Admin__UserName=
Bootstrap__Admin__Email=
Bootstrap__Admin__Password=
The production-only behavior remains protected unless
Bootstrap__Admin__AllowOutsideProduction=false
